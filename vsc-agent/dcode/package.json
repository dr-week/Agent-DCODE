{
  "name": "agent-dcode",
  "displayName": "Agent-DCODE",
  "description": "Offline AI Agent - Send code to local AI and get responses",
  "version": "0.1.0",
  "publisher": "dishant",
  "repository": {
    "type": "git",
    "url": "https://github.com/dishant/agent-dcode"
  },
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "AI",
    "Developer Tools"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "dcode.sendToAI",
        "title": "Send to DCODE AI",
        "category": "DCODE"
      },
      {
        "command": "dcode.agent",
        "title": "Open Agent Mode",
        "category": "DCODE"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "dcode-explorer",
          "title": "DCODE AI",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "dcode-explorer": [
        {
          "type": "webview",
          "id": "dcode.sidebar",
          "name": "Chat"
        }
      ]
    },
    "configuration": {
      "title": "DCODE AI",
      "properties": {
        "dcode.apiKey": {
          "type": "string",
          "default": "",
          "description": "OpenAI API key"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "npm run check-types && node esbuild.js --production",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "openai": "^4.26.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/node": "22.x",
    "typescript": "^5.9.3",
    "esbuild": "^0.27.3"
  }
}
